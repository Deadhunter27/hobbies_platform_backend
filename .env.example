# Environment the app is running in: development | test | production
NODE_ENV=development

# HTTP port the Nest app listens on
PORT=3000

# Postgres connection string — matches docker-compose.yml's local credentials
DATABASE_URL=postgresql://hobbies:hobbies@localhost:5432/hobbies_dev

# Pino log level: fatal | error | warn | info | debug | trace
LOG_LEVEL=info

# HS256 signing secret for access JWTs (ADR-0017). Min 32 chars; generate
# with: openssl rand -base64 48. NEVER reuse this placeholder anywhere.
JWT_SECRET=local-dev-only-secret-change-me-0000000000

# Access JWT lifetime in seconds (default 900 = 15 min, ADR-0017)
ACCESS_TOKEN_TTL_SECONDS=900

# Refresh token lifetime in days (default 14, ADR-0017)
REFRESH_TOKEN_TTL_DAYS=14
