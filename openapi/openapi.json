  "info": {
    "title": "Hobbies Platform API",
    "description": "Public API for the Hobbies Platform backend.",
    "version": "1.0",
    "contact": {}
  },
  "tags": [],
  "servers": [],
  "components": {
    "securitySchemes": {
      "bearer": {
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "type": "http"
      }
    },
    "schemas": {
      "HobbyCategoriesResponseDto": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "string"
                },
                "parentId": {
                  "type": "string",
                  "nullable": true
                },
                "name": {
                  "type": "string"
                },
                "slug": {
                  "type": "string"
                },
                "description": {
                  "type": "string",
                  "nullable": true
                },
                "sortOrder": {
                  "type": "number"
                },
                "createdAt": {
                  "type": "string"
                },
                "updatedAt": {
                  "type": "string"
                }
              },
              "required": [
                "id",
                "parentId",
                "name",
                "slug",
                "description",
                "sortOrder",
                "createdAt",
                "updatedAt"
              ]
            }
          }
        },
        "required": [
          "data"
        ]
      },
      "PaginatedHobbiesResponseDto": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "string"
                },
                "categoryId": {
                  "type": "string"
                },
                "name": {
                  "type": "string"
                },
                "slug": {
                  "type": "string"
                },
                "description": {
                  "type": "string",
                  "nullable": true
                },
                "difficulty": {
                  "type": "string",
                  "enum": [
                    "beginner_friendly",
                    "moderate",
                    "demanding"
                  ]
                },
                "costLevel": {
                  "type": "string",
                  "enum": [
                    "free",
                    "low",
                    "medium",
                    "high"
                  ]
                },
                "setting": {
                  "type": "string",
                  "enum": [
                    "indoor",
                    "outdoor",
                    "both"
                  ]
                },
                "createdAt": {
                  "type": "string"
                },
                "updatedAt": {
                  "type": "string"
                }
              },
              "required": [
                "id",
                "categoryId",
                "name",
                "slug",
                "description",
                "difficulty",
                "costLevel",
                "setting",
                "createdAt",
                "updatedAt"
              ]
            }
          },
          "page": {
            "type": "object",
            "properties": {
              "nextCursor": {
                "type": "string",
                "nullable": true
              },
              "hasMore": {
                "type": "boolean"
              }
            },
            "required": [
              "nextCursor",
              "hasMore"
            ]
          }
        },
        "required": [
          "data",
          "page"
        ]
      },
      "ErrorEnvelopeDto": {
        "type": "object",
        "properties": {
          "error": {
            "type": "object",
            "properties": {
              "code": {
                "type": "string"
              },
              "message": {
                "type": "string"
              },
              "details": {
                "type": "array",
                "items": {}
              }
            },
            "required": [
              "code",
              "message",
              "details"
            ]
          }
        },
        "required": [
          "error"
        ]
      },
      "HobbyResponseDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "categoryId": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "slug": {
            "type": "string"
          },
          "description": {
            "type": "string",
            "nullable": true
          },
          "difficulty": {
            "type": "string",
            "enum": [
              "beginner_friendly",
              "moderate",
              "demanding"
            ]
          },
          "costLevel": {
            "type": "string",
            "enum": [
              "free",
              "low",
              "medium",
              "high"
            ]
          },
          "setting": {
            "type": "string",
            "enum": [
              "indoor",
              "outdoor",
              "both"
            ]
          },
          "createdAt": {
            "type": "string"
          },
          "updatedAt": {
            "type": "string"
          }
        },
        "required": [
          "id",
          "categoryId",
          "name",
          "slug",
          "description",
          "difficulty",
          "costLevel",
          "setting",
          "createdAt",
          "updatedAt"
        ]
      },
      "RegisterBodyDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "maxLength": 320,
            "format": "email",
            "pattern": "^(?!\\.)(?!.*\\.\\.)([A-Za-z0-9_'+\\-\\.]*)[A-Za-z0-9_+-]@([A-Za-z0-9][A-Za-z0-9\\-]*\\.)+[A-Za-z]{2,}$"
          },
          "password": {
            "type": "string",
            "minLength": 1,
            "maxLength": 200
          },
          "displayName": {
            "type": "string",
            "minLength": 1,
            "maxLength": 120
          }
        },
        "required": [
          "email",
          "password",
          "displayName"
        ],
        "additionalProperties": false
      },
      "UserResponseDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "email": {
            "type": "string"
          },
          "displayName": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "active",
              "suspended",
              "deleted"
            ]
          },
          "globalRole": {
            "type": "string",
            "enum": [
              "user",
              "staff"
            ]
          },
          "createdAt": {
            "type": "string"
          }
        },
        "required": [
          "id",
          "email",
          "displayName",
          "status",
          "globalRole",
          "createdAt"
        ]
      },
      "LoginBodyDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
