                "$ref": "#/components/schemas/ChangePasswordBodyDto"
              }
            }
          }
        },
        "responses": {
          "204": {
            "description": "Password changed, every session revoked"
          },
          "400": {
            "description": "VALIDATION_FAILED or PASSWORD_TOO_WEAK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorEnvelopeDto"
                }
              }
            }
          },
          "401": {
            "description": "UNAUTHORIZED or INVALID_CREDENTIALS (wrong current password)",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorEnvelopeDto"
                }
              }
            }
          }
        },
        "security": [
          {
            "bearer": []
          }
        ],
        "summary": "Change password; revokes ALL sessions (ADR-0017)",
        "tags": [
          "auth"
        ]
      }
