    "/api/v1/hobby-categories": {
      "get": {
        "operationId": "HobbyCategoriesController_list_v1",
        "parameters": [],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HobbyCategoriesResponseDto"
                }
              }
            }
          }
        },
        "summary": "List active hobby categories, ordered",
        "tags": [
          "hobby-categories"
        ]
      }
    },
    "/api/v1/hobbies": {
      "get": {
        "operationId": "HobbiesController_list_v1",
        "parameters": [
          {
            "name": "category",
            "required": false,
            "in": "query",
            "description": "Category slug filter",
            "schema": {
              "minLength": 1,
              "type": "string"
            }
          },
          {
            "name": "difficulty",
            "required": false,
            "in": "query",
            "description": "Repeatable difficulty filter",
            "schema": {
              "anyOf": [
                {
                  "type": "string",
                  "enum": [
                    "beginner_friendly",
                    "moderate",
                    "demanding"
                  ]
                },
                {
                  "type": "array",
                  "items": {
                    "type": "string",
                    "enum": [
                      "beginner_friendly",
                      "moderate",
                      "demanding"
                    ]
                  }
                }
              ],
              "items": {}
            }
          },
          {
            "name": "q",
            "required": false,
            "in": "query",
            "description": "Free-text search on hobby name",
            "schema": {
              "minLength": 1,
              "type": "string"
            }
          },
          {
            "name": "limit",
            "required": false,
            "in": "query",
            "description": "Page size (default 20, max 100)",
            "schema": {
              "maximum": 100,
              "exclusiveMinimum": true,
              "default": 20,
              "type": "number",
              "minimum": 0
            }
          },
          {
            "name": "cursor",
            "required": false,
            "in": "query",
            "description": "Opaque pagination cursor",
            "schema": {
              "minLength": 1,
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PaginatedHobbiesResponseDto"
                }
              }
            }
          },
          "400": {
            "description": "VALIDATION_FAILED (unknown/malformed query param) or INVALID_CURSOR",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorEnvelopeDto"
                }
              }
            }
          }
        },
        "summary": "List active hobbies, cursor-paginated",
        "tags": [
          "hobbies"
        ]
      }
    },
    "/api/v1/hobbies/{slugOrId}": {
      "get": {
        "operationId": "HobbiesController_get_v1",
        "parameters": [
          {
            "name": "slugOrId",
            "required": true,
            "in": "path",
            "description": "Hobby slug or ULID",
            "schema": {
              "minLength": 1,
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HobbyResponseDto"
                }
              }
            }
          },
          "404": {
            "description": "HOBBY_NOT_FOUND",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorEnvelopeDto"
                }
              }
            }
          }
        },
        "summary": "Get one active hobby by slug or id",
        "tags": [
          "hobbies"
        ]
      }
    }
  },
  "info": {
    "title": "Hobbies Platform API",
    "description": "Public API for the Hobbies Platform backend.",
    "version": "1.0",
    "contact": {}
  },
